library(tidyverse)
library(janitor)
library(naniar)
library(ggmap)
library(lubridate)
library(shiny)
register_stadiamaps("95fc2c89-4097-40d9-aa48-b0ba8bad5a00", write = FALSE)
polar_bears <-
read_csv("data/polarBear_serumUreaCreatinine_beaufortChukchi_rode.csv") %>%
clean_names() %>%
select(-den_method, -no_cubs, -cub_age) %>%
filter(age_class==c("A", "S")) %>%
mutate(sex=toupper(sex),
age_class=toupper(age_class))
names(polar_bears)
glimpse(polar_bears)
polar_bears %>%
summarise(across(everything(), ~sum(is.na(.))))
polar_bears
"No explicit NAs in given dataset"
polar_bears.no.nas <- #creating new with NA values replaced with NA
polar_bears %>%
replace_with_na_all(condition = ~.x %in% c(common_na_numbers, common_na_strings))
polar_bears.no.nas %>%
summarize(across(everything(), ~sum(is.na(.))))
"Returns that there is one NA somewhere"
polar_bears %>% #looking for the polar bear with NA urea nitrogen level
filter(urea_nitrogen == (common_na_numbers) | urea_nitrogen == common_na_strings)
"One polar bear has a urea nitrogen level of 66, which fits into the common replacements for NA. I will consider this an NA and keep the replacement."
polar_bears.no.nas %>%
group_by(popn) %>%
ggplot(mapping = aes(x = popn, fill = sex)) +
geom_bar(position = "dodge") +
labs(title = "Number of Males and Females Represented in Each Population", x = "Population", y = "Count")
"Sampling is relatively even for both sexes in each population, but there were a few more females tested in population SB."
polar_bears.no.nas <- polar_bears.no.nas %>%
separate(capture_date, c("year", "month", "day"), "-")
polar_bears.no.nas %>%
count(year) %>%
ggplot(aes(x = year, y = n)) +
geom_line(na.rm = T, color = "orange") +
geom_point(shape = 5) +
labs(title = "Amount of Bears Sampled Each Year for Both CS and SB populations", x = "Year", y = "Count") +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
#Urea Nitrogen:
polar_bears.no.nas %>%
select(urea_nitrogen) %>%
mutate(min.urea.nitrogen = min(polar_bears.no.nas$urea_nitrogen, na.rm = T),
max.urea.nitrogen = max(polar_bears.no.nas$urea_nitrogen, na.rm = T),
mean.urea.nitrogen = mean(polar_bears.no.nas$urea_nitrogen, na.rm = T),
median.urea.nitrogen = median(polar_bears.no.nas$urea_nitrogen, na.rm = T)) %>%
select(min.urea.nitrogen, max.urea.nitrogen, mean.urea.nitrogen, median.urea.nitrogen) %>%
distinct()
#Creatinine:
polar_bears.no.nas %>%
select(creatinine) %>%
mutate(min.creatinine = min(polar_bears.no.nas$creatinine, na.rm = T),
max.creatinine = max(polar_bears.no.nas$creatinine, na.rm = T),
mean.creatinine = mean(polar_bears.no.nas$creatinine, na.rm = T),
median.creatinine = median(polar_bears.no.nas$creatinine, na.rm = T)) %>%
select(min.creatinine, max.creatinine, mean.creatinine, median.creatinine) %>%
distinct()
#being asked to make new variables
polar_bears.no.nas <-
polar_bears.no.nas %>%
mutate(un_creat_ratio = (urea_nitrogen*0.466)/creatinine)
#being asked to make new variables
polar_bears.no.nas <-
polar_bears.no.nas %>%
mutate(fasting = case_when(un_creat_ratio <= 10  ~ "fasting",
un_creat_ratio >10 ~ "not fasting"))
polar_bears.no.nas
polar_bears.no.nas %>%
select(year, popn, fasting) %>%
filter(fasting == "fasting") %>%
group_by(year) %>%
ggplot(aes(x = year)) +
geom_bar(mapping = aes(fill = popn), position = "dodge") +
theme(axis.text.x = element_text(angle = 45, hjust = 1)) +
labs(title = "Fasting Bears per Population by Year", x = "Year", y = "Count")
bearslong <- polar_bears.no.nas %>%
select(long)
bearslat <- polar_bears.no.nas %>%
select(lat)
bearsbbox <- make_bbox(bearslong, bearslat, f = 0.03)
bearsmap <- get_stadiamap(bearsbbox, maptype = "stamen_terrain", zoom = 5)
ggmap(bearsmap) +
geom_point(data = polar_bear.no.nas, aes(long, lat, color = popn), size = 0.5)
library(shiny)
ui <- fluidPage(
selectInput("fill",
"Select Fill Variable",
choices = c("sex", "mating", "age_class", "denning",  "fasting")),
plotOutput(
"plot", width = "500px", height = "500px"
)
)
server <- function(input, output, session) {
output$plot <- renderPlot(
polar_bears.no.nas %>%
ggplot(aes(x = popn, y = un_creat_ratio, fill = .data[[input$fill]])) +
geom_boxplot() +
labs(title = "Urea Nitrogen Levels/Creatinine For Polar Bear Populations", x = "Population", y = "UN/Creatinine")
)
}
shinyApp(ui, server)
library(shiny)
ui <- fluidPage(
selectInput("fill",
"Select Fill Variable",
choices = c("sex", "mating", "age_class", "denning",  "fasting")),
plotOutput(
"plot", width = "500px", height = "500px"
)
)
