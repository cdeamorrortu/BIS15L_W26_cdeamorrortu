choices = c("sex", "mating", "age_class", "denning",  "fasting")),
plotOutput(
"plot", width = "500px", height = "500px"
)
)
server <- function(input, output, session) {
output$plot <- renderPlot(
polar_bear.no.nas %>%
ggplot(aes(x = popn, y = un_creat_ratio, fill = .data[[input$fill]])) +
geom_boxplot() +
labs(title = "Urea Nitrogen Levels/Creatinine For Polar Bear Populations", x = "Population", y = "UN/Creatinine", legent = "Fill Variable")
)
}
shinyApp(ui, server)
