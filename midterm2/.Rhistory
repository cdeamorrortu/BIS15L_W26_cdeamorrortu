output$plot <- renderPlot({
polar_bears.no.nas %>%
ggplot(aes(x = popn, y = un_creat_ratio, fill = .data[[input$fill]])) +
geom_boxplot() +
labs(title = "Urea Nitrogen Levels/Creatinine For Polar Bear Populations", x = "Population", y = "UN/Creatinine")
})
}
shinyApp(ui, server)
