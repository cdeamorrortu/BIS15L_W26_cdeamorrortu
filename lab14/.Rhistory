library(tidyverse)
library(janitor)
library(ggmap)
library(leaflet)
register_stadiamaps("95fc2c89-4097-40d9-aa48-b0ba8bad5a00", write = FALSE)
sharks <- read_csv("data/SharkIncidents_1950_2022_220302.csv") %>%
clean_names() %>%
filter(longitude !="NA" & latitude !="NA") %>% # pulling out NA locations
mutate(longitude = as.numeric(longitude)) # converting longitude to numeric
sharkslong <- sharks %>%
select(longitude)
sharkslat <- sharks %>%
select(latitude)
sharksbbox <- make_bbox(sharkslong, sharkslat, f = 0.03)
sharksmap <- get_stadiamap(sharksbbox, maptype = "stamen_terrain", zoom = 7)
ggmap(sharksmap)
ggmap(sharksmap) +
geom_point(data = sharks, aes(longitude, latitude), size = 0.5, color = "firebrick") +
labs(title = "Shark Attacks in California", x = "longitude", y = "latitude")
fatalsharks <- sharks %>%
select(injury, longitude, latitude) %>%
filter(injury == "fatal")
ggmap(sharksmap) +
geom_point(data = fatalsharks, aes(longitude, latitude), size = 0.5, color = "red") +
labs(title = "Fatal Shark Attacks Along California Coast", x = "Longitude", y = "Latitude")
leaflet(fatalsharks) %>%
addProviderTiles(providers$Stadia.StamenTerrain) %>%
addCircleMarkers(
lng = ~longitude,
lat = ~latitude,
radius = 2,
stroke = FALSE,
color = "black",
fillOpacity = 0.7
) %>%
addScaleBar(position = "bottomleft") %>%
fitBounds(lng1 = min(sharks$longitude), lat1 = min(sharks$latitude), lng2 = max(sharks$longitude), lat2 = max(sharks$latitude))
sdsharks <-  sharks %>%
filter(county == "San Diego")
leaflet(sdsharks) %>%
addProviderTiles(providers$Stadia.StamenTerrain) %>%
addCircleMarkers(
lng = ~longitude,
lat = ~latitude,
radius = 2,
stroke = FALSE,
color = "black",
fillOpacity = 0.7
) %>%
addScaleBar(position = "bottomleft") %>%
fitBounds(lng1 = min(sharks$longitude), lat1 = min(sharks$latitude), lng2 = max(sharks$longitude), lat2 = max(sharks$latitude))
