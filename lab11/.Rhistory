filter(country == "USA")  %>%
mutate(gdp = signif(gdp, 1), pop = signif(pop, 1)) %>%
select(year, gdp, pop) %>%
mutate("gdp/100" = gdp/100, "pop/10,000" = pop/10000) %>%
select(year, `gdp/100`, `pop/10,000`)
