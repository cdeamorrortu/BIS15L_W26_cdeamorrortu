knitr::opts_chunk$set(echo = TRUE)
library(tidyverse)
library(janitor)
options(scipen = 999)
gapminder <- read_csv("data/gapminder.csv") %>%
clean_names() %>%
filter(between(year, 1925, 2025))
glimpse(gapminder)
gapminder %>%
count(country) %>%
select(n) %>%
distinct()
newminder <-  gapminder %>%
filter(year == 1925 | year == 2025) %>%
select(country, year, pop) %>%
mutate(year = as.factor(year)) %>%
pivot_wider(names_from = year, values_from = pop)
newminder %>%
mutate("difference" = (`2025` - `1925`)) %>%
select(country, difference) %>%
arrange(desc(difference)) %>%
slice_head(n = 5)
gapminder %>%
select(country, year, pop) %>%
filter(country == "India") %>%
ggplot(aes(x = year, y = pop)) +
geom_line(color = "orange") +
geom_point(shape = 5)
gapminder %>%
filter(year == 1925 | year == 2025) %>%
select(country, year, lex) %>%
mutate(year = as.factor(year)) %>%
pivot_wider(names_from = year, values_from = lex) %>%
mutate(lex.diff = `2025`-`1925`, na.rm = T) %>%
select(lex.diff) %>%
arrange(desc(lex.diff)) %>%
mutate(lex.diff.min = min(lex.diff, na.rm = T), lex.diff.max = max(lex.diff, na.rm = T), lex.diff.med = median(lex.diff, na.rm = T), lex.diff.mean = mean(lex.diff, na.rm = T)) %>%
select(lex.diff.max, lex.diff.min, lex.diff.mean, lex.diff.med) %>%
slice_head(n=1)
gapminder %>%
filter(year %in% c(1925, 2025)) %>%
mutate(year = factor(year)) %>%
ggplot(aes(x = lex, color = year, fill = year)) +
geom_density(alpha = 0.3) +
labs(title = "Distribution of Life Expectancy, 1925 and 2025", x = "Life Expectancy (years)", y = NULL) +
scale_fill_manual( values = c("1925" = "magenta", "2025" = "yellow"))
"The average life expectancy shifted by about 40 years in the 100 year timespan"
gapminder %>%
filter(year == 2025)  %>%
mutate(gdp = signif(gdp, 3), lex = signif(lex, 2)) %>%
ggplot(aes(x = lex, y = gdp)) +
geom_col(mapping = aes(x = lex, y = gdp)) +
labs(title = "Estimated Life Expectancy By GDP", x = "Life Expectancy (Years)", y = "GDP")
