mutate(gdp.diff = `2025`-`1975`, na.rm = T) %>%
select(country, gdp.diff) %>%
arrange(desc(gdp.diff)) %>%
slice_head(n = 5)
"Monaco has the highest change in GDP in in the past 50 years"
